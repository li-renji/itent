{
  "WeChat": {
    "process_names": ["WeChat.exe"],
    "tombstone_mode": "suspend",
    "never_suspend": {
      "description": "语音/视频通话时不墓碑",
      "detect_window_class": ["WeChatVoipWindow", "VoipWindow"],
      "detect_child_process": ["WeChatVoipHelper.exe"]
